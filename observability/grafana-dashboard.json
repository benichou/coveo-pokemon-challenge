{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "The Loki data source for the pokemon-search log stream",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Coveo Pokemon Challenge — query-level observability. One log record per completed search, captured browser-side and forwarded through a Vercel serverless proxy to Grafana Cloud Loki. See docs/observability.md for architecture.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "title": "GitHub repo",
      "type": "link",
      "url": "https://github.com/benichou/coveo-pokemon-challenge",
      "targetBlank": true,
      "icon": "external link"
    },
    {
      "title": "Live search UI",
      "type": "link",
      "url": "https://pokemon-search-one-chi.vercel.app",
      "targetBlank": true,
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Top queries (selected window)",
      "type": "barchart",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Most-searched queries in the selected time range. Bounded to top 20 to keep the panel readable. `q != \"\"` strips empty-query state changes Atomic emits on initial page load.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "options": {
        "orientation": "horizontal",
        "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "", "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "topk(20, sum by (q) (count_over_time({app=\"pokemon-search\"} | json | q != `` [$__range])))",
          "queryType": "instant",
          "legendFormat": "{{q}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "RGA fire rate (selected window)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Share of searches that produced a settled RGA answer (`isAnswerGenerated=true`). Watch for drops — could indicate a Coveo model issue, a sort=non-relevancy regression (RGA refuses to ground), or a content gap.",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({app=\"pokemon-search\", rga_fired=\"true\"}[$__range])) / sum(count_over_time({app=\"pokemon-search\"}[$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate (4xx/5xx)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Share of searches where Coveo returned a non-200 status. Should be ~0%. Spikes mean rate-limiting, auth issues, pipeline misconfig, or platform incident.",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 5 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "noValue": "0%"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({app=\"pokemon-search\", status!=\"200\"}[$__range])) / sum(count_over_time({app=\"pokemon-search\"}[$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "title": "Query volume",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Searches per minute over time. Use to spot traffic spikes, dips, or a sudden cutoff (e.g., the UI broke and stopped firing searches at all).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "options": {
        "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "searches/min",
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({app=\"pokemon-search\"}[$__interval]))",
          "legendFormat": "searches",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 5,
      "title": "Coveo response latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Distribution of Coveo Search API response times, in milliseconds. p95 is the headline number for user-perceived latency. p99 catches the tail-latency events Coveo support would want to triage.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "avg by () (quantile_over_time(0.50, {app=\"pokemon-search\"} | json | __error__=\"\" | unwrap response_time_ms [5m]))",
          "legendFormat": "p50",
          "queryType": "range"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "avg by () (quantile_over_time(0.95, {app=\"pokemon-search\"} | json | __error__=\"\" | unwrap response_time_ms [5m]))",
          "legendFormat": "p95",
          "queryType": "range"
        },
        {
          "refId": "C",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "avg by () (quantile_over_time(0.99, {app=\"pokemon-search\"} | json | __error__=\"\" | unwrap response_time_ms [5m]))",
          "legendFormat": "p99",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 6,
      "title": "Sort criteria distribution",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Which sort do users actually pick? Relevancy dominating is healthy. Spike in Name/Date suggests users couldn't find what they wanted via relevance — content or RGA quality signal.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true, "values": ["percent", "value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "displayName": "${__field.labels.sort_criteria}"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (sort_criteria) (count_over_time({app=\"pokemon-search\"} | json | sort_criteria != `` [$__range]))",
          "legendFormat": "{{sort_criteria}}",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 7,
      "title": "Search hub mix",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Which search hubs (logical app surfaces) traffic comes through. Single-hub today (pokemon-search); kept here to show how multi-app deployments would slice the same dashboard.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 26 },
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true, "values": ["percent", "value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "displayName": "${__field.labels.search_hub}"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (search_hub) (count_over_time({app=\"pokemon-search\"}[$__range]))",
          "legendFormat": "{{search_hub}}",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 8,
      "title": "Live search logs (tabular)",
      "type": "table",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Per-search log records as a sortable table — one row per completed search. Columns: time, query, sort, RGA fired, RGA answer (truncated), latency, total results, status. Click any column header to sort; click any cell value to filter the dashboard. Hidden by default: top_results array, citations, facets_active, client_id, pipeline (all available via the dashboard's expand-row feature or Explore).",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 35 },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "countRows": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rga_answer" },
            "properties": [
              { "id": "custom.width", "value": 400 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "q" },
            "properties": [
              { "id": "displayName", "value": "query" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "response_time_ms" },
            "properties": [
              { "id": "displayName", "value": "latency (ms)" },
              { "id": "unit", "value": "ms" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_count" },
            "properties": [
              { "id": "displayName", "value": "results" },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rga_fired" },
            "properties": [
              { "id": "displayName", "value": "RGA" },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sort_criteria" },
            "properties": [
              { "id": "displayName", "value": "sort" },
              { "id": "custom.width", "value": 110 }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json",
            "keepTime": true,
            "replace": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "tsNs": true,
              "labels": true,
              "id": true,
              "labelTypes": true,
              "search_hub": true,
              "pipeline": true,
              "client_id": true,
              "facets_active": true,
              "top_results": true,
              "rga_requested": true,
              "rga_citations_count": true,
              "timestamp": true
            },
            "indexByName": {
              "Time": 0,
              "q": 1,
              "sort_criteria": 2,
              "rga_fired": 3,
              "rga_answer": 4,
              "response_time_ms": 5,
              "total_count": 6,
              "status": 7
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{app=\"pokemon-search\"}",
          "queryType": "range",
          "maxLines": 200
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["coveo", "pokemon", "observability", "search"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Coveo Pokemon Search — query observability",
  "uid": "pokemon-search-observability",
  "version": 1,
  "weekStart": ""
}
