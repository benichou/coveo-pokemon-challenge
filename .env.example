# =============================================================================
# Coveo Pokemon Challenge — environment variables
# Copy this file to .env and fill in the values. See docs/api-keys.md for how
# to mint each API key in the Coveo Admin Console.
# =============================================================================

# ---------- Core organization ----------

# Your Coveo org id (find in Admin Console URL or Organization → Settings)
COVEO_ORG_ID=your-org-id-here


# ---------- Coveo API keys (5 total — one per role, least-privilege) ----------

# Key 1 — Push API template
# Used by: push-pokemon/ Python ingestion pipeline (Phase 4)
# See docs/api-keys.md → Key 1
COVEO_PUSH_API_KEY=your-push-api-key-here

# Key 2 — Custom template (Sources + Fields + Pipelines Edit, ML Models View)
# Used by: scripts/ — source config, mappings, fields, rebuilds, pipeline associations
# See docs/api-keys.md → Key 2
COVEO_ADMIN_API_KEY=your-admin-api-key-here

# Key 3 — Anonymous Search template, bound to "pokemon-search" search hub
# Used by: tests/, atomic-search/ UI (browser-side), rga-eval/ /generate calls
# Public-safe by design (Anonymous Search template; Coveo allows this in browsers).
# See docs/api-keys.md → Key 3
COVEO_SEARCH_API_KEY=your-search-api-key-here

# Key 4 — Custom template (Knowledge.Answer Manager: Edit only)
# Used by: rga-eval/src/coveo_rga.py to discover the answer-config id at startup.
# Does NOT execute queries (that needs Execute Query, which only the search key has).
# See docs/api-keys.md → Key 4
COVEO_RGA_JUDGE_API_KEY=your-rga-judge-api-key-here

# Key 5 — Custom template (Machine Learning Models: Edit only)
# Used by: rga-closed-loop/src/apply.py to PUT RGA Custom Prompt updates to
# /machinelearning/models/{id}. The admin key's Sources+Fields scope is NOT
# sufficient (returns 403); this is a dedicated least-privilege ML write key.
# See docs/api-keys.md → Key 5
COVEO_ML_MODELS_API_KEY=your-ml-models-api-key-here


# ---------- Coveo Answer Config id (optional cache) ----------

# Optional but recommended — caches the RGA answer-config discovery API call
# so rga-eval/ doesn't hit Coveo for it on every run. If unset, the eval
# discovers it at startup via /answer/v1/configs (works either way).
# Find it via: curl -H "Authorization: Bearer $COVEO_RGA_JUDGE_API_KEY" \
#   "https://platform.cloud.coveo.com/rest/organizations/$COVEO_ORG_ID/answer/v1/configs" \
#   | jq -r '.items[0].id'
COVEO_RGA_CONFIG_ID=

# ---------- Anthropic ----------

# Personal Anthropic API key from console.anthropic.com.
# Used by: rga-eval/src/llm_judge.py (Sonnet 4.6 LLM-as-judge) and
#          rga-closed-loop/src/analyzer.py (closed-loop prompt analyzer).
# Do NOT use a corporate Anthropic key on this repo — it's personal infra,
# and corporate-key usage on a personal GitHub project is an audit/compliance
# concern (see ~/.claude/rules/security.md).
ANTHROPIC_API_KEY=sk-ant-api03-your-personal-anthropic-key-here


# ---------- Source IDs (auto-populated by scripts/bootstrap.sh) ----------

COVEO_SITEMAP_SOURCE_ID=your-sitemap-source-id-here
COVEO_PUSH_SOURCE_ID=your-push-source-id-here


# ---------- Phase 6E observability: Grafana Cloud Loki (via Vercel proxy) ----------

# Architecture: browser → POST /api/log-query (Vercel serverless function) → Loki.
# Loki's /push endpoint doesn't support browser CORS preflights (405 on OPTIONS),
# so we use a same-origin serverless proxy. The proxy lives at
# atomic-search/api/log-query.js. Server-side env vars (NO VITE_ prefix) keep
# the Loki write token out of the browser bundle entirely.
# See docs/observability.md for the full architecture story.

# Reference values (for re-deriving the base64 auth string after rotation).
# NOT read by application code — humans-only reference.
COVEO_GRAFANA_LOKI_USER=your-numeric-loki-user-id-here
COVEO_GRAFANA_LOKI_TOKEN=glc_your-grafana-cloud-token-here

# What the Vercel serverless function (atomic-search/api/log-query.js) reads.
# These MUST be set in Vercel project env vars (Settings → Environment Variables).
# Locally in this file they're only used if you run `vercel dev` (otherwise
# the dev kill-switch silences browser logging on localhost).
# Compute GRAFANA_LOKI_AUTH via:
#   USER=$(grep '^COVEO_GRAFANA_LOKI_USER=' .env | cut -d= -f2-)
#   TOKEN=$(grep '^COVEO_GRAFANA_LOKI_TOKEN=' .env | cut -d= -f2-)
#   echo -n "${USER}:${TOKEN}" | base64
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_AUTH=your-base64-encoded-auth-string-here

# Browser-side kill-switch. Default: silent no-op in `npm run dev` (kill-switch
# auto-triggers because the proxy doesn't exist locally); enabled in production
# builds. Set to "false" to force-disable in production too.
# VITE_OBSERVABILITY_ENABLED=false


# ---------- Frontend (Vite) — mirrors for browser access ----------

# These get baked into the atomic-search/ build at build time. Only the
# search key is safe to expose in the browser (Anonymous Search template).
# Never mirror the admin / push / judge / ml-models keys here.
VITE_COVEO_ORG_ID=${COVEO_ORG_ID}
VITE_COVEO_SEARCH_API_KEY=${COVEO_SEARCH_API_KEY}
