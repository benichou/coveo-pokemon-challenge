# Coveo organization
COVEO_ORG_ID=your-org-id-here

# Push API key (used by push-pokemon/ Python ingestion)
# Privileges needed: Push source Edit + Content/Sources View
COVEO_PUSH_API_KEY=your-push-api-key-here

# Push source ID (created in Phase 4 of the plan)
COVEO_PUSH_SOURCE_ID=your-push-source-id-here

# Search token (used by the frontend Atomic + Headless apps)
# Either a search-scoped API key, or a server-minted search token
VITE_COVEO_ORG_ID=${COVEO_ORG_ID}
VITE_COVEO_SEARCH_TOKEN=your-search-token-here
