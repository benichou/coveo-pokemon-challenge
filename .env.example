# =============================================================================
# Coveo Pokemon Challenge — environment variables
# Copy this file to .env and fill in the values. See docs/api-keys.md for how
# to mint each API key in the Coveo Admin Console.
# =============================================================================

# Coveo organization
COVEO_ORG_ID=your-org-id-here

# Push API key — Push API template, ~30 day expiry
# Used by: scripts/ (limited), push-pokemon/ Python ingestion (Phase 4)
# Privileges: Push items to sources, Sources View all
# See docs/api-keys.md → Key 1
COVEO_PUSH_API_KEY=your-push-api-key-here

# Admin key — Custom template (Sources Edit + Fields Edit), ~30 day expiry
# Used by: scripts/ (most of them)
# Privileges: Content > Sources > Edit, Content > Fields > Edit
# See docs/api-keys.md → Key 2
COVEO_ADMIN_API_KEY=your-admin-api-key-here

# Search API key — Anonymous Search template, ~30 day expiry, bound to "pokemon-search" search hub
# Used by: tests/, Atomic UI (browser-side queries), Phase 5+
# Privileges: Execute queries, Analytics data Push (public-safe)
# See docs/api-keys.md → Key 3
COVEO_SEARCH_API_KEY=your-search-api-key-here

# Source IDs (resolved from the API — created by scripts/create_source.sh)
COVEO_SITEMAP_SOURCE_ID=your-sitemap-source-id-here
COVEO_PUSH_SOURCE_ID=your-push-source-id-here

# Frontend (Vite) — mirrors of the above for browser access
VITE_COVEO_ORG_ID=${COVEO_ORG_ID}
VITE_COVEO_SEARCH_API_KEY=${COVEO_SEARCH_API_KEY}
